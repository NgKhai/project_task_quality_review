<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_stage_todo" model="project.task.type">
        <field name="name">To-do</field>
        <field name="sequence">1</field>
    </record>
    <record id="project_stage_in_progress" model="project.task.type">
        <field name="name">In Progress</field>
        <field name="sequence">2</field>
    </record>
    <record id="project_stage_review" model="project.task.type">
        <field name="name">Ready for Review</field>
        <field name="sequence">3</field>
    </record>
    <record id="project_stage_done" model="project.task.type">
        <field name="name">Done</field>
        <field name="sequence">4</field>
        <field name="fold" eval="True"/>
    </record>
</odoo>
